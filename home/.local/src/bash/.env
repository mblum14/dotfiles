export TERMINAL=gnome-terminal

# don't put duplicate lines or lines starting with space in the history.
# See bash(1) for more options
HISTCONTROL=ignoreboth

# for setting history length see HISTSIZE and HISTFILESIZE in bash(1)
HISTSIZE=1000
HISTFILESIZE=2000

EDITOR=/usr/bin/nvim
TERM=screen-256color

PATH=$HOME/.local/bin:$HOME/.cargo/bin:$HOME/Library/Python/3.11/bin:/usr/local/bin:/usr/local/sbin:/usr/bin:/bin:/usr/sbin:/sbin
MYVIMRC=$HOME/.local/nvim/init.vim

JAVA_HOME=/Library/Java/JavaVirtualMachines/openjdk.jdk

export HOMEBREW_PREFIX="/usr/local";
export HOMEBREW_CELLAR="/usr/local/Cellar";
export HOMEBREW_REPOSITORY="/usr/local/Homebrew";

export RUST_SRC_PATH="$(rustc --print sysroot)/lib/rustlib/src/rust/src"

export FZF_DEFAULT_COMMAND='fdfind --type f --hidden --follow --exclude .git --exclude node_modules'
export FZF_COMPLETION_TRIGGERS='**'
export FZF_COMPLETION_OPTS='+c -x'

export MANPAGER="sh -c 'col -bx | bat -l man -p'"
export MANPATH="/usr/local/share/man${MANPATH+:$MANPATH}:"
export INFOPATH="/usr/local/share/info:${INFOPATH:-}"

# enable ls coloring
export CLICOLOR=1

#source $(brew --prefix asdf)/libexec/asdf.sh
source /usr/local/opt/asdf/libexec/asdf.sh
