export TERMINAL=gnome-terminal

# don't put duplicate lines or lines starting with space in the history.
# See bash(1) for more options
HISTCONTROL=ignoreboth

# for setting history length see HISTSIZE and HISTFILESIZE in bash(1)
HISTSIZE=1000
HISTFILESIZE=2000

EDITOR=/usr/bin/nvim
TERM=screen-256color

export GOPATH=/alt/.local/lib/go
PATH=$HOME/.local/bin:$HOME/.cargo/bin:$GOPATH/bin:/snap/bin::$PATH
MYVIMRC=$HOME/.local/nvim/init.vim
JAVA_HOME=/usr/lib/jvm/default-java
JDK_HOME=/usr/lib/jvm/default-java

export RUST_SRC_PATH="$(rustc --print sysroot)/lib/rustlib/src/rust/src"

export FZF_DEFAULT_COMMAND='fdfind --type f --hidden --follow --exclude .git --exclude node_modules'
export FZF_COMPLETION_TRIGGERS='**'
export FZF_COMPLETION_OPTS='+c -x'

export MANPAGER="sh -c 'col -bx | bat -l man -p'"
